# game/indepth_text.rpy:22
translate indonesian a_label_8d79d234:

    # e "You just clicked to jump to a label."
    e "Anda baru saja mengklik untuk melompat ke sebuah label."

# game/indepth_text.rpy:28
translate indonesian text_578c4060:

    # e "Sometimes, when showing text, we'll want to change the way some of the text is displayed."
    e "Terkadang, saat menampilkan teks, kita ingin mengubah cara beberapa bagian teks tersebut ditampilkan."

# game/indepth_text.rpy:31
translate indonesian text_60750345:

    # e "For example, we might want to have text that is {b}bold{/b}, {i}italic{/i}, {s}struckthrough{/s}, or {u}underlined{/u}."
    e "Sebagai contoh, kita mungkin ingin teks yang {b}tebal (bold){/b}, {i}miring (italic){/i}, {s}dicoret (struckthrough){/s}, atau {u}bergaris bawah (underlined){/u}."

# game/indepth_text.rpy:33
translate indonesian text_5e1a6ee8:

    # e "That's what text tags are for."
    e "Itulah kegunaan dari tag teks."

# game/indepth_text.rpy:37
translate indonesian text_38c63ec8:

    # e "Text tags are contained in braces, like the {{b} tag above. When a text tag takes a closing tag, the closing tag begins with a slash, like {{/b} does."
    e "Tag teks ditulis di dalam kurung kurawal, seperti tag {{b} di atas. Ketika sebuah tag teks memerlukan tag penutup, tag penutup tersebut diawali dengan garis miring, seperti {{/b}."

# game/indepth_text.rpy:39
translate indonesian text_1760f9c8:

    # e "We've already seen the b, i, s, and u tags, but there are lot more than those. I'll show you the rest of them."
    e "Kita sudah melihat tag b, i, s, dan u, tetapi masih banyak tag lainnya. Saya akan menunjukkan sisanya kepada Anda."

# game/indepth_text.rpy:43
translate indonesian text_a620251f:

    # e "The a text tag can {a=https://www.renpy.org}link to a website{/a} or {a=jump:a_label}jump to a label{/a}."
    e "Tag teks 'a' dapat {a=https://www.renpy.org}menautkan ke sebuah situs web{/a} atau {a=jump:a_label}melompat ke sebuah label{/a}."

# game/indepth_text.rpy:49
translate indonesian after_a_label_d22d5f4a:

    # e "The alpha text tag makes text {alpha=.5}translucent{/alpha}."
    e "Tag teks 'alpha' membuat teks menjadi {alpha=.5}translusen (semi-transparan){/alpha}."

# game/indepth_text.rpy:53
translate indonesian after_a_label_7c2c3cd2:

    # e "The color text tag changes the {color=#0080c0}color{/color} of the text."
    e "Tag teks 'color' mengubah {color=#0080c0}warna{/color} teks."

# game/indepth_text.rpy:57
translate indonesian after_a_label_3f81fe7b:

    # e "The cps text tag {cps=25}makes text type itself out slowly{/cps}, even if slow text is off."
    e "Tag teks 'cps' {cps=25}membuat teks mengetik dirinya sendiri secara perlahan{/cps}, meskipun fitur teks lambat sedang dimatikan."

# game/indepth_text.rpy:59
translate indonesian after_a_label_b102941f:

    # e "The cps tag can also be relative to the default speed, {cps=*2}doubling{/cps} or {cps=*0.5}halving{/cps} it."
    e "Tag 'cps' juga bisa bersifat relatif terhadap kecepatan default, {cps=*2}melipatgandakan{/cps} atau {cps=*0.5}menguranginya menjadi setengah{/cps} dari kecepatan aslinya."

# game/indepth_text.rpy:64
translate indonesian after_a_label_22c4339a:

    # e "The font tag changes the font, for example to {font=DejaVuSans-Bold.ttf}DejaVuSans-Bold.ttf{/font}."
    e "Tag 'font' mengubah jenis huruf (font), misalnya menjadi {font=DejaVuSans-Bold.ttf}DejaVuSans-Bold.ttf{/font}."

# game/indepth_text.rpy:66
translate indonesian after_a_label_d43417d7:

    # e "Sometimes, changing to a bold font looks better than using the {{b} tag."
    e "Terkadang, beralih ke font yang memang tebal terlihat lebih bagus daripada menggunakan tag {{b}."

# game/indepth_text.rpy:71
translate indonesian after_a_label_f24052f9:

    # e "The k tag changes kerning. It can space the letters of a word {k=-.5}closer together{/k} or {k=.5}farther apart{/k}."
    e "Tag 'k' mengubah kerning (jarak antar huruf). Ini bisa membuat huruf-huruf dalam sebuah kata menjadi {k=-.5}lebih rapat{/k} atau {k=.5}lebih renggang{/k}."

# game/indepth_text.rpy:76
translate indonesian after_a_label_2310b922:

    # e "The size tag changes the size of text. It can make text {size=+10}bigger{/size} or {size=-10}smaller{/size}, or set it to a {size=30}fixed size{/size}."
    e "Tag 'size' mengubah ukuran teks. Ini bisa membuat teks menjadi {size=+10}lebih besar{/size}, {size=-10}lebih kecil{/size}, atau mengaturnya ke {size=30}ukuran tetap{/size}."

# game/indepth_text.rpy:81
translate indonesian after_a_label_f566abf2:

    # e "The space tag {space=30} adds horizontal space in text.{vspace=30}The vspace tag adds vertical space between lines."
    e "Tag 'space' {space=30} menambahkan ruang horizontal pada teks.{vspace=30}Tag 'vspace' menambahkan ruang vertikal di antara baris."

# game/indepth_text.rpy:85
translate indonesian after_a_label_054b9ffa:

    # e "There are a few text tags that only makes sense in dialogue."
    e "Ada beberapa tag teks yang hanya masuk akal jika digunakan dalam dialog."

# game/indepth_text.rpy:89
translate indonesian after_a_label_86efc45b:

    # e "The p tag breaks a paragraph,{p}and waits for the player to click."
    e "Tag 'p' memutus paragraf,{p}dan menunggu pemain untuk melakukan klik."

# game/indepth_text.rpy:91
translate indonesian after_a_label_3ece2387:

    # e "If it is given a number as an argument,{p=1.5}it waits that many seconds."
    e "Jika diberikan angka sebagai argumen,{p=1.5}ia akan menunggu selama sekian detik tersebut."

# game/indepth_text.rpy:95
translate indonesian after_a_label_3881f72d:

    # e "The w tag also waits for a click,{w} except it doesn't break lines,{w=.5} the way p does."
    e "Tag 'w' juga menunggu klik,{w} hanya saja ia tidak memutus baris,{w=.5} tidak seperti yang dilakukan oleh tag 'p'."

# game/indepth_text.rpy:100
translate indonesian after_a_label_e5321e79:

    # eslow "The nw tag causes Ren'Py to continue past slow text,{nw}"
    eslow "Tag 'nw' menyebabkan Ren'Py terus berlanjut melewati teks lambat,{nw}"

# game/indepth_text.rpy:102
translate indonesian after_a_label_1f2697ba:

    # extend " to the next statement."
    extend " ke pernyataan berikutnya secara otomatis."

# game/indepth_text.rpy:106
translate indonesian after_a_label_dbfca166:

    # e "To break a line without pausing,\none can write \\n. \\' and \\\" include quotes in the text."
    e "Untuk memutus baris tanpa jeda,\nAnda bisa menulis \\n. \\' dan \\\" digunakan untuk menyertakan tanda kutip di dalam teks."

# game/indepth_text.rpy:111
translate indonesian after_a_label_ffdf7e76:

    # e "The interpolation feature takes a variable name in square brackets, and inserts it into text."
    e "Fitur interpolasi mengambil nama variabel di dalam kurung siku, dan memasukkannya ke dalam teks."

# game/indepth_text.rpy:117
translate indonesian after_a_label_fc99fcbf:

    # e "For example, this displays the [variable!t]."
    e "Sebagai contoh, ini menampilkan [variable!t]."

# game/indepth_text.rpy:121
translate indonesian after_a_label_c84d9087:

    # e "When the variable name is followed by !q, special characters are quoted. This displays the raw [variable!q!t], including the italics tags."
    e "Ketika nama variabel diikuti oleh !q, karakter spesial akan diberi tanda kutip. Ini menampilkan [variable!q!t] mentah, termasuk tag miringnya."

# game/indepth_text.rpy:126
translate indonesian after_a_label_c90f24a8:

    # e "When the variable name is followed by !t, it is translated to [variable!t]. It could be something else in a different language."
    e "Ketika nama variabel diikuti oleh !t, ia akan diterjemahkan menjadi [variable!t]. Isinya bisa jadi berbeda dalam bahasa lain."

# game/indepth_text.rpy:129
translate indonesian after_a_label_fb106a95:

    # e "Finally, certain characters are special. [[, {{, and \\ need to be doubled if included in text. The %% character should be doubled if used in dialogue."
    e "Terakhir, karakter tertentu bersifat spesial. [[, {{, dan \\ perlu ditulis ganda jika ingin dimasukkan ke dalam teks. Karakter %% juga harus ditulis ganda jika digunakan dalam dialog."

translate indonesian strings:

    # game/indepth_text.rpy:115
    old "{i}variable value{/i}"
    new "{i}variable value{/i}"

    # game/indepth_text.rpy:124
    old "translatable text"
    new "translatable text"

