# game/tutorial_nvlmode.rpy:71
translate indonesian after_nvl_menu_cb560cd2:

    # nvle "Games can mix NVL-mode and the normal ADV-mode by having some characters that have kind=nvl, and some that do not."
    nvle "Game dapat menggabungkan NVL-mode dan ADV-mode normal dengan memiliki beberapa karakter yang memiliki 'king=vnl', dan beberapa yang tidak."

# game/tutorial_nvlmode.rpy:73
translate indonesian after_nvl_menu_10a6e85a:

    # e "You can specify transitions that occur when going from NVL-mode to ADV-mode."
    e "Kamu dapat menentukan transisi yang terjadi saat beralih dari NVL-mode ke ADV-mode."

# game/tutorial_nvlmode.rpy:75
translate indonesian after_nvl_menu_d43b28d1:

    # nvle "As well as when going from ADV-mode to NVL-mode."
    nvle "Begitu juga sebaliknya, dari ADV-mode ke NVL-mode."

# game/tutorial_nvlmode.rpy:77
translate indonesian after_nvl_menu_f056c7ad:

    # nvle "Text tags like {{w}{w} work in NVL-mode."
    nvle "Tag teks seperti {{W}{W} berfungsi dalam NVL-mode."

# game/tutorial_nvlmode.rpy:79
translate indonesian after_nvl_menu_750cd9a1:

    # extend " As does the \"extend\" special character."
    extend "Begitu juga dengan karakter khusus \"extend\"."

