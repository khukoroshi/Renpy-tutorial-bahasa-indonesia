# game/tutorial_nvlmode.rpy:22
translate indonesian tutorial_nvlmode_ac125210:

    # nvle "NVL-style games are games that cover the full screen with text, rather then placing it in a window at the bottom of the screen. Like this."
    nvle "NVL-style games adalah game yang menutupi seluruh layar dengan teks, bukan menempatkannya dalam jendela di bagian bawah layar. Seperti ini."

# game/tutorial_nvlmode.rpy:26
translate indonesian tutorial_nvlmode_e7030787:

    # nvle "To use NVL-mode, you need to define Characters with a kind=nvl."
    nvle "Untuk menggunakan NVL-mode, kamu perlu mendefinisikan Characters dengan 'kind=nvl'."

# game/tutorial_nvlmode.rpy:30
translate indonesian tutorial_nvlmode_c9a35125:

    # nvle "Then just use that character in a say statement."
    nvle "Kemudian gunakan saja karakter tersebut dalam sebuah pernyataan."

# game/tutorial_nvlmode.rpy:32
translate indonesian tutorial_nvlmode_130610c2:

    # nvl clear
    # nvle "You use 'nvl clear' to clear the screen when that becomes necessary."
    nvl clear
    nvle "kamu menggunakan 'nvl clear' untuk membersihkan layar bila diperlukan."

# game/tutorial_nvlmode.rpy:39
translate indonesian tutorial_nvlmode_390a4eb1:

    # nvle "The 'nvl show' and 'nvl hide' statements use transitions to show and hide the NVL window."
    nvle "Pernyataan 'nvl show' dan 'nvl hide' menggunakan transisi untuk menampilkan dan menyembunyikan jendela NVL."

# game/tutorial_nvlmode.rpy:52
translate indonesian tutorial_nvlmode_05956e33:

    # nvle "NVL-mode also supports showing menus to the player, providing it's the last thing on the screen. Understand?" nointeract
    nvle "NVL-mode juga mendukung tampilan menu kepada player, asalkan menu tersebut merupakan hal terakhir yang ditampilkan di layar. Paham?" nointeract

